# Supabase (Postgres) — Settings > Database di dashboard Supabase
DATABASE_URL=
DIRECT_URL=

# Password admin dashboard & storefront (header x-admin-secret). Buat string baru
# yang unik untuk toko ini, jangan pakai nilai dari toko lain.
ADMIN_SECRET=

# Midtrans (Settings > Access Keys, pakai key MODE PRODUKSI untuk go-live)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true

# Domain storefront (dipakai sebagai finish_redirect_url Midtrans & link di email)
FRONTEND_URL=https://hanun-store-catalog.vercel.app

# Gmail pengirim email (gunakan App Password, bukan password akun biasa:
# https://myaccount.google.com/apppasswords)
EMAIL_USER=
EMAIL_PASS=

# Fonnte (fonnte.com) — token device untuk kirim WA
FONNTE_TOKEN=

# Bot Telegram admin (@BotFather untuk token, @userinfobot untuk chat id)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Opsional ---

# Batasi asal request CORS (pisah koma). Kosongkan untuk izinkan semua origin.
ALLOWED_ORIGINS=

# Secret webhook opt-in. HANYA isi jika pengirim (Google Apps Script / Telegram)
# sudah dipastikan mengirim header/secret_token yang cocok — kalau tidak,
# webhook akan diam-diam ditolak (lihat CLAUDE.md bagian "Auth & Keamanan").
GAS_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_SECRET=
